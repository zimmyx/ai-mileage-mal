# Telegram bot token from BotFather
TELEGRAM_MILEAGE_BOT_TOKEN=123456789:your_telegram_bot_token

# Your own Telegram chat ID for Friday reminder messages
MY_CHAT_ID=123456789

# OpenRouter API key for AI mileage extraction
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# Google Sheets service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_MILEAGE_SHEET_ID=your_google_sheet_id

# Mileage claim rate per km
MILEAGE_RATE=0.60

# Server port, optional locally. Render usually sets this automatically.
PORT=8080

# Render webhook URL. Leave empty for local polling mode.
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com
